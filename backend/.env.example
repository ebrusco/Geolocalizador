# Google API key (server-side, restricted to Places API New + Geocoding)
GOOGLE_API_KEY=your-google-api-key-here

# PostgreSQL connection (Neon or Supabase)
DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# Frontend origin for CORS
FRONTEND_URL=http://localhost:5173

# Server
HOST=0.0.0.0
PORT=8000

# Neon Auth (Better Auth) — leave empty to disable auth
NEON_AUTH_URL=

# Admin emails (comma-separated) — these users can manage the access list
ALLOWED_EMAILS=

# Environment: development or production
# In production, auth failures return 503 instead of bypassing
ENVIRONMENT=development
